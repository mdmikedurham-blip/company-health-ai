# Supabase (PostgreSQL)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Drive OAuth (read-only)
# Create an OAuth client in Google Cloud Console; redirect to your app callback.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/connectors/google-drive/callback

# AES-256 key for encrypting refresh tokens at rest (64 hex chars = 32 bytes)
# Generate: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# Optional: HMAC secret for OAuth state (defaults to TOKEN_ENCRYPTION_KEY)
OAUTH_STATE_SECRET=

# Company UUID in Supabase `companies` table used when connecting Drive
# (mock UI id "company-acme" is not a UUID — set a real company id for OAuth storage)
DEFAULT_COMPANY_ID=

# Protects /api/cron/sync-connectors and /api/connectors/google-drive/sync
# Vercel Cron sends Authorization: Bearer <CRON_SECRET> automatically when set.
CRON_SECRET=

# Optional local fallback refresh token (skips DB) for crawler experiments
# GOOGLE_DRIVE_REFRESH_TOKEN=
