# Company Health AI — environment variables
# Copy to .env.local for local development. Never commit secrets.

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
# Prefer publishable key when available; anon key is the fallback.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL used for email confirmation + password reset redirects.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Google Drive OAuth (server-only) ─────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match an authorized redirect URI in Google Cloud Console, e.g.:
# http://localhost:3000/api/connectors/google-drive/callback
GOOGLE_OAUTH_REDIRECT_URI=

# AES-256 key material for encrypting Drive refresh tokens at rest (64 hex chars).
TOKEN_ENCRYPTION_KEY=
# Optional dedicated HMAC secret for OAuth state (falls back to TOKEN_ENCRYPTION_KEY).
OAUTH_STATE_SECRET=

# ─── Jobs ─────────────────────────────────────────────────────────────────────
# Optional for upload processing (in-process kickoff does not require it).
# Still used for cron routes and optional HTTP observability to /api/documents/process.
DOCUMENT_PROCESS_SECRET=
CRON_SECRET=
